        <SolidColorBrush x:Key="BgColor">#0f1218</SolidColorBrush>
        <SolidColorBrush x:Key="ButtonColor">#414c61</SolidColorBrush>
        <SolidColorBrush x:Key="ButtonHoverColor">#5e687d</SolidColorBrush>
        <SolidColorBrush x:Key="DangerColor">#ef4444</SolidColorBrush>
        <SolidColorBrush x:Key="DangerHoverColor">#f87171</SolidColorBrush>
        <SolidColorBrush x:Key="SuccessColor">#22c55e</SolidColorBrush>
        <SolidColorBrush x:Key="SuccessHoverColor">#4ade80</SolidColorBrush>
        <SolidColorBrush x:Key="InfoColor">#3b82f6</SolidColorBrush>
        <SolidColorBrush x:Key="InfoColorHover">#60a5fa</SolidColorBrush>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        
        <Style Selector="Window">
            <Setter Property="Background" Value="#0f1218"/>
        </Style>
        
        <Style Selector="TextBlock">
            <Setter Property="FontFamily"
                    Value="Segoe UI, Noto Color Emoji"/>
            <Setter Property="Foreground" Value="White"></Setter>
        </Style>
        
        <Style Selector="Button.Base:pressed">
            <Setter Property="RenderTransform" Value="none" />
        </Style>

        <Style Selector="Button.Base">
            <Setter Property="FontSize" Value="24"></Setter>
            <Setter Property="FontWeight" Value="ExtraBold"></Setter>
            <Setter Property="Background" Value="{StaticResource ButtonColor}" />
            <Setter Property="Foreground" Value="White"></Setter>
            <Setter Property="Cursor" Value="hand"></Setter>
            <Setter Property="Padding" Value="10 5"></Setter>
        </Style>
        <Style Selector="Button.Base /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ButtonColor}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="White" />
            <Setter Property="Cursor" Value="hand"></Setter>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.1" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.Base:pointerover">
            <Setter Property="BorderBrush" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.Base:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ButtonHoverColor}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        
    </Application.Styles>
</Application>