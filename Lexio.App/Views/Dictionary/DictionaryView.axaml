<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:dictionary="clr-namespace:Lexio.App.ViewModels.Dictionary"
             x:Class="Lexio.App.Views.Dictionary.DictionaryView"
             x:DataType="dictionary:DictionaryViewModel">
    <Grid>
        <Grid Margin="0 10" VerticalAlignment="Top" HorizontalAlignment="Stretch" RowDefinitions="Auto, Auto"
              RowSpacing="10">

            <Border Grid.Row="0" HorizontalAlignment="Stretch" BorderBrush="White"
                    Padding="10">
                <Border
                    BorderThickness="0 0 0 1"
                    BorderBrush="White"
                    Padding="0 0 0 5">
                    <TextBlock
                        Grid.Row="0"
                        HorizontalAlignment="Stretch"
                        FontSize="24"
                        FontWeight="ExtraBold">
                        ↳ Gérer les langues et les différents mots disponibles
                    </TextBlock>
                </Border>
            </Border>

            <Border Grid.Row="1" Padding="5 0">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button
                        Grid.Row="1"
                        Command="{Binding RoutingService.GoLanguageManagementCommand}"
                        CommandParameter="Test query dictionary view"
                        Classes="Base"
                        CornerRadius="10"
                        Padding="20 10"
                        HorizontalAlignment="Left">
                        <StackPanel>
                            <StackPanel Spacing="5" HorizontalAlignment="Center" Orientation="Horizontal">
                                <TextBlock>👅</TextBlock>
                            </StackPanel>
                            <TextBlock>LANGUAGES</TextBlock>
                        </StackPanel>
                    </Button>
                    
                    
                    <Button
                        Grid.Row="1"
                        Command="{Binding RoutingService.GoLanguageManagementCommand}"
                        CommandParameter="Test query dictionary view"
                        Classes="Base"
                        CornerRadius="10"
                        Padding="20 10"
                        HorizontalAlignment="Left">
                        <StackPanel>
                            <StackPanel Spacing="5" HorizontalAlignment="Center" Orientation="Horizontal">
                                <TextBlock>✒️</TextBlock>
                            </StackPanel>
                            <TextBlock>GESTION DES MOTS</TextBlock>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>

</UserControl>