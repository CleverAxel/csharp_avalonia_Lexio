<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:dictionary="clr-namespace:Lexio.App.ViewModels.Dictionary"
             x:DataType="dictionary:LanguageManagementViewModel"
             x:Class="Lexio.App.Views.Dictionary.LanguageManagementView">
    <UserControl.Styles>
        <Style Selector="Button.Base">
            <Setter Property="Padding" Value="10"></Setter>
        </Style>
        <Style Selector="Button.Edit /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource InfoColor}" />
        </Style>
        <Style Selector="Button.Edit:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource InfoColorHover}" />
        </Style>

        <Style Selector="Button.Delete /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DangerColor}" />
        </Style>
        <Style Selector="Button.Delete:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DangerHoverColor}" />
        </Style>
    </UserControl.Styles>
    <Grid>
        <ScrollViewer VerticalAlignment="Top" VerticalScrollBarVisibility="Auto">
            <ListBox x:Name="ListLanguages" ItemsSource="{Binding LanguageModels}" Background="Transparent">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Margin" Value="0 0 0 5"></Setter>
                        <Setter Property="FontSize" Value="18"></Setter>
                        <Setter Property="CornerRadius" Value="10"></Setter>
                        <Setter Property="Background" Value="#5e687d" />
                        <Setter Property="MaxWidth" Value="500" />
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#5e687d" />
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="#5e687d" />
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto, *">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Name}" />
                                <TextBlock Opacity="0.5" Text="{Binding Code}" />
                            </StackPanel>  
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
                                <Button Classes="Base Edit">
                                    <PathIcon 
                                        Width="20" 
                                        Height="20" 
                                        Foreground="White"
                                        Data="{StaticResource EditRegular}"></PathIcon>
                                </Button>
                                <Button 
                                    Classes="Base Delete"
                                    Command="{Binding $parent[ListBox].((dictionary:LanguageManagementViewModel)DataContext).DeleteCommand}"
                                    CommandParameter="{Binding .}">
                                    <PathIcon 
                                        Width="20" 
                                        Height="20" 
                                        Foreground="White"
                                        Data="{StaticResource DeleteRegular}"></PathIcon>
                                </Button>
                            </StackPanel>

                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>
    </Grid>
</UserControl>