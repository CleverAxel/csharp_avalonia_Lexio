<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:dictionary="clr-namespace:Lexio.App.ViewModels.Dictionary"
             x:DataType="dictionary:LanguageManagementViewModel"
             x:Class="Lexio.App.Views.Dictionary.LanguageManagementView">
    <UserControl.Styles>
        <Style Selector="Button.Base">
            <Setter Property="Padding" Value="10"></Setter>
        </Style>
        <Style Selector="Button.Edit /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource InfoColor}" />
        </Style>
        <Style Selector="Button.Edit:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource InfoColorHover}" />
        </Style>

        <Style Selector="Button.Delete /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DangerColor}" />
        </Style>
        <Style Selector="Button.Delete:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DangerHoverColor}" />
        </Style>
        <Style Selector="AutoCompleteBox:focus">
            <Setter Property="Foreground" Value="Black"></Setter>
        </Style>
        <Style Selector="AutoCompleteBox">
            <Setter Property="Background" Value="{StaticResource ButtonColor}"></Setter>
            <Setter Property="Foreground" Value="White"></Setter>
            <Setter Property="FontSize" Value="20"></Setter>
            <Setter Property="Padding" Value="10"></Setter>
        </Style>
    </UserControl.Styles>
    <Grid ColumnDefinitions="450, *">
        <StackPanel Margin="20" Spacing="12">

            <!-- Title -->
            <TextBlock
                Margin="0 20"
                HorizontalAlignment="Center"
                FontSize="24"
                Foreground="White"
                FontWeight="ExtraBold">
                + Ajouter une autre langue
            </TextBlock>

            <AutoCompleteBox Name="AutoCompleteBoxLanguage" ItemsSource="{Binding AvailableLanguageModels}"
                             SelectedItem="{Binding SelectedLanguage}"
                             FilterMode="Contains"
                             MinimumPrefixLength="0">
                <AutoCompleteBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type dictionary:LanguageViewModel}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding Flag}" />
                            <TextBlock Foreground="Black" Text="{Binding Name}" />
                        </StackPanel>
                    </DataTemplate>
                </AutoCompleteBox.ItemTemplate>
                <AutoCompleteBox.KeyBindings>
                    <KeyBinding Gesture="Enter" Command="{Binding AddNewLanguageCommand}"></KeyBinding>
                </AutoCompleteBox.KeyBindings>
            </AutoCompleteBox>

            <!-- Submit Button -->
            <Button x:Name="SubmitButton"
                    Classes="Base Submit"
                    Command="{Binding AddNewLanguageCommand}"
                    Background="{StaticResource SuccessColor}"
                    HorizontalAlignment="Stretch">
                <Button.Styles>
                    <Style Selector="Button.Submit /template/ ContentPresenter">
                        <Setter Property="Background" Value="{StaticResource SuccessColor}" />
                    </Style>
                    <Style Selector="Button.Submit:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="{StaticResource SuccessHoverColor}" />
                    </Style>
                </Button.Styles>
                <TextBlock HorizontalAlignment="Center">Ajouter</TextBlock>
            </Button>

            <Border
                IsVisible="{Binding ShowLanguageAlreadyExist}"
                Background="White"
                Padding="10"
                CornerRadius="10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                    <PathIcon Data="{StaticResource ErrorCircleRegular}" Width="20" Height="20" Foreground="{StaticResource DangerColor}"></PathIcon>
                    <TextBlock

                        Foreground="{StaticResource DangerColor}"
                        FontWeight="ExtraBold"
                        FontSize="18">
                        Cette langue existe déjà dans la liste.
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
        <ScrollViewer Grid.Column="1" VerticalAlignment="Top" VerticalScrollBarVisibility="Auto">
            <ListBox Name="ListLanguages" x:Name="ListLanguages" Padding="0 10"
                     ItemsSource="{Binding AddedLanguageModels}"
                     Background="Transparent">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="BorderThickness" Value="2"></Setter>
                        <Setter Property="BorderBrush" Value="{StaticResource ButtonHoverColor}"></Setter>
                        <Setter Property="Margin" Value="0 0 0 5"></Setter>
                        <Setter Property="FontSize" Value="18"></Setter>
                        <Setter Property="CornerRadius" Value="10"></Setter>
                        <Setter Property="Background" Value="#5e687d" />
                    </Style>
                    <Style Selector="ListBoxItem.border">
                        <Setter Property="BorderBrush" Value="{StaticResource ButtonHoverColor}"></Setter>
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#5e687d" />
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="#5e687d" />
                    </Style>
                    <Style Selector="ListBoxItem.blink">
                        <Style.Animations>
                            <Animation Duration="0:0:0.75" IterationCount="3" FillMode="Forward">
                                <KeyFrame Cue="0%">
                                    <Setter Property="BorderBrush" Value="{StaticResource ButtonHoverColor}" />
                                </KeyFrame>
                                <KeyFrame Cue="25%">
                                    <Setter Property="BorderBrush" Value="{StaticResource SuccessColor}" />
                                </KeyFrame>
                                <KeyFrame Cue="50%">
                                    <Setter Property="BorderBrush" Value="White" />
                                </KeyFrame>
                                <KeyFrame Cue="75%">
                                    <Setter Property="BorderBrush" Value="{StaticResource SuccessColor}" />
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                    <Setter Property="BorderBrush" Value="{StaticResource ButtonHoverColor}" />
                                </KeyFrame>
                            </Animation>
                        </Style.Animations>
                    </Style>


                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto, *">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                                <TextBlock Text="{Binding Flag}" />
                                <TextBlock Text="{Binding Name}" />
                                <TextBlock Opacity="0.5" Text="{Binding Code}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5"
                                        HorizontalAlignment="Right">
                                <!-- <Button Classes="Base Edit"> -->
                                <!--     <PathIcon -->
                                <!--         Width="20" -->
                                <!--         Height="20" -->
                                <!--         Foreground="White" -->
                                <!--         Data="{StaticResource EditRegular}"> -->
                                <!--     </PathIcon> -->
                                <!-- </Button> -->
                                <Button
                                    Classes="Base Delete"
                                    Command="{Binding $parent[ListBox].((dictionary:LanguageManagementViewModel)DataContext).DeleteCommand}"
                                    CommandParameter="{Binding .}">
                                    <PathIcon
                                        Width="20"
                                        Height="20"
                                        Foreground="White"
                                        Data="{StaticResource DeleteRegular}">
                                    </PathIcon>
                                </Button>
                            </StackPanel>

                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>
    </Grid>
</UserControl>