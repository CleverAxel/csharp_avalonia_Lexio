<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Lexio.App.Views.Dictionary.Word.WordManagementView"
             xmlns:word="clr-namespace:Lexio.App.ViewModels.Dictionary.Word"
             x:DataType="word:WordManagementViewModel">

    <StackPanel>
        <ListBox ItemsSource="{Binding FilterChars}"
                 Background="Transparent"
                 HorizontalAlignment="Center">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"
                               ItemSpacing="2"
                               LineSpacing="2" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="MinWidth" Value="0" />
                </Style>
                <Style Selector="Button.Base">
                    <Setter Property="Opacity" Value="0.5" />
                </Style>
                <Style Selector="Button.Base.Active">
                    <Setter Property="Opacity" Value="1" />
                </Style>
            </ListBox.Styles>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Button Classes="Base"
                            Classes.Active="{Binding IsSelected}"
                            Command="{Binding $parent[ListBox].((word:WordManagementViewModel)DataContext).ApplyCharFilterCommand}"
                            CommandParameter="{Binding Char}">
                        <TextBlock Text="{Binding Char}" />
                    </Button>
                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>
        <Border Margin="10" HorizontalAlignment="Center">
            <Button Classes="Base" Command="{Binding AddNewWordCommand}">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <PathIcon Data="{StaticResource AddSquareRegular}" Width="20" Height="20" Foreground="White"></PathIcon>
                    <TextBlock>Ajouter un nouveau mot</TextBlock>
                </StackPanel>
            </Button>
        </Border>
    </StackPanel>
</UserControl>