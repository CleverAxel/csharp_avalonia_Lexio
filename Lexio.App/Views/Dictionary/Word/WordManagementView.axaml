<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Lexio.App.Views.Dictionary.Word.WordManagementView"
             xmlns:word="clr-namespace:Lexio.App.ViewModels.Dictionary.Word"
             x:DataType="word:WordManagementViewModel">
    
    <UserControl.Styles>

        <Style Selector="Button.Delete /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DangerColor}" />
            <Setter Property="Width" Value="40"></Setter>
            <Setter Property="Height" Value="40"></Setter>
        </Style>
        <Style Selector="Button.Delete:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DangerHoverColor}" />
        </Style>
        
        <Style Selector="Button.Edit /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource InfoColor}" />
            <Setter Property="Width" Value="40"></Setter>
            <Setter Property="Height" Value="40"></Setter>
        </Style>
        <Style Selector="Button.Edit:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource InfoColorHover}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, Auto, *">
        <ListBox ItemsSource="{Binding FilterChars}"
                 Background="Transparent"
                 HorizontalAlignment="Center">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"
                               ItemSpacing="2"
                               LineSpacing="2" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="MinWidth" Value="0" />
                </Style>
                <Style Selector="Button.Base">
                    <Setter Property="Opacity" Value="0.5" />
                </Style>
                <Style Selector="Button.Base.Active">
                    <Setter Property="Opacity" Value="1" />
                </Style>
            </ListBox.Styles>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Button Classes="Base"
                            Classes.Active="{Binding IsSelected}"
                            Command="{Binding $parent[ListBox].((word:WordManagementViewModel)DataContext).ApplyCharFilterCommand}"
                            CommandParameter="{Binding Char}">
                        <TextBlock Text="{Binding Char}" />
                    </Button>
                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>
        <Border Grid.Row="1" Margin="10" HorizontalAlignment="Center">
            <Button Classes="Base" Command="{Binding AddNewWordCommand}">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <PathIcon Data="{StaticResource AddSquareRegular}" Width="20" Height="20" Foreground="White"></PathIcon>
                    <TextBlock>Ajouter un nouveau mot</TextBlock>
                </StackPanel>
            </Button>
        </Border>
        
        
        <ScrollViewer Grid.Row="2" VerticalAlignment="Top" VerticalScrollBarVisibility="Auto">
            <ListBox Name="ListLanguages" x:Name="ListLanguages" Padding="0 10"
                     ItemsSource="{Binding WordList}"
                     Background="Transparent">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="BorderThickness" Value="2"></Setter>
                        <Setter Property="BorderBrush" Value="{StaticResource ButtonHoverColor}"></Setter>
                        <Setter Property="Margin" Value="0 0 0 5"></Setter>
                        <Setter Property="FontSize" Value="18"></Setter>
                        <Setter Property="CornerRadius" Value="10"></Setter>
                        <Setter Property="Background" Value="#5e687d" />
                    </Style>
                    <Style Selector="ListBoxItem.border">
                        <Setter Property="BorderBrush" Value="{StaticResource ButtonHoverColor}"></Setter>
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#5e687d" />
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="#5e687d" />
                    </Style>
                    <Style Selector="ListBoxItem.blink">
                        <Style.Animations>
                            <Animation Duration="0:0:0.75" IterationCount="3" FillMode="Forward">
                                <KeyFrame Cue="0%">
                                    <Setter Property="BorderBrush" Value="{StaticResource ButtonHoverColor}" />
                                </KeyFrame>
                                <KeyFrame Cue="25%">
                                    <Setter Property="BorderBrush" Value="{StaticResource SuccessColor}" />
                                </KeyFrame>
                                <KeyFrame Cue="50%">
                                    <Setter Property="BorderBrush" Value="White" />
                                </KeyFrame>
                                <KeyFrame Cue="75%">
                                    <Setter Property="BorderBrush" Value="{StaticResource SuccessColor}" />
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                    <Setter Property="BorderBrush" Value="{StaticResource ButtonHoverColor}" />
                                </KeyFrame>
                            </Animation>
                        </Style.Animations>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto, *">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                                <TextBlock Text="{Binding Name}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5"
                                        HorizontalAlignment="Right">
                                <Button
                                    Classes="Base Edit"
                                    Command="{Binding $parent[ListBox].((word:WordManagementViewModel)DataContext).EditWordCommand}"
                                    CommandParameter="{Binding .}">
                                    <PathIcon
                                        Width="20"
                                        Height="20"
                                        Foreground="White"
                                        Data="{StaticResource EditRegular}">
                                    </PathIcon>
                                </Button>
                                <Button
                                    Classes="Base Delete"
                                    Command="{Binding $parent[ListBox].((word:WordManagementViewModel)DataContext).DeleteWordCommand}"
                                    CommandParameter="{Binding .}">
                                    <PathIcon
                                        Width="20"
                                        Height="20"
                                        Foreground="White"
                                        Data="{StaticResource DeleteRegular}">
                                    </PathIcon>
                                </Button>
                            </StackPanel>

                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>
        
    </Grid>
</UserControl>