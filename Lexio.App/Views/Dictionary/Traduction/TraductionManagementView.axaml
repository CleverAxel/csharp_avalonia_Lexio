<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:traduction="clr-namespace:Lexio.App.ViewModels.Dictionary.Traduction"
             x:DataType="traduction:TraductionManagementViewModel"
             x:Class="Lexio.App.Views.Dictionary.Traduction.TraductionManagementView">
    <UserControl.Styles>

        <Style Selector="Button.Delete /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DangerColor}" />
            <Setter Property="Width" Value="40"></Setter>
            <Setter Property="Height" Value="40"></Setter>
        </Style>
        <Style Selector="Button.Delete:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DangerHoverColor}" />
        </Style>
        
        <Style Selector="Button.Edit /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource InfoColor}" />
            <Setter Property="Width" Value="40"></Setter>
            <Setter Property="Height" Value="40"></Setter>
        </Style>
        <Style Selector="Button.Edit:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource InfoColorHover}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, Auto">
        <ListBox ItemsSource="{Binding FilterChars}"
                 Background="Transparent"
                 HorizontalAlignment="Center">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"
                               ItemSpacing="2"
                               LineSpacing="2" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="MinWidth" Value="0" />
                </Style>
                <Style Selector="Button.Base">
                    <Setter Property="Opacity" Value="0.5" />
                </Style>
                <Style Selector="Button.Base.Active">
                    <Setter Property="Opacity" Value="1" />
                </Style>
            </ListBox.Styles>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Button Classes="Base"
                            Classes.Active="{Binding IsSelected}"
                            Command="{Binding $parent[ListBox].((traduction:TraductionManagementViewModel)DataContext).ApplyCharFilterCommand}"
                            CommandParameter="{Binding Char}">
                        <TextBlock Text="{Binding Char}" />
                    </Button>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <ScrollViewer Grid.Row="1" VerticalAlignment="Top" VerticalScrollBarVisibility="Auto">
            
            <ListBox Name="ListLanguages" x:Name="ListLanguages" Padding="0 10"
                     ItemsSource="{Binding TraductionList}"
                     Background="Transparent">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="BorderThickness" Value="2"></Setter>
                        <Setter Property="BorderBrush" Value="{StaticResource ButtonHoverColor}"></Setter>
                        <Setter Property="Margin" Value="0 0 0 5"></Setter>
                        <Setter Property="FontSize" Value="18"></Setter>
                        <Setter Property="CornerRadius" Value="10"></Setter>
                        <Setter Property="Background" Value="#5e687d" />
                    </Style>
                    <Style Selector="ListBoxItem.border">
                        <Setter Property="BorderBrush" Value="{StaticResource ButtonHoverColor}"></Setter>
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#5e687d" />
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="#5e687d" />
                    </Style>
                    <Style Selector="ListBoxItem.blink">
                        <Style.Animations>
                            <Animation Duration="0:0:0.75" IterationCount="3" FillMode="Forward">
                                <KeyFrame Cue="0%">
                                    <Setter Property="BorderBrush" Value="{StaticResource ButtonHoverColor}" />
                                </KeyFrame>
                                <KeyFrame Cue="25%">
                                    <Setter Property="BorderBrush" Value="{StaticResource SuccessColor}" />
                                </KeyFrame>
                                <KeyFrame Cue="50%">
                                    <Setter Property="BorderBrush" Value="White" />
                                </KeyFrame>
                                <KeyFrame Cue="75%">
                                    <Setter Property="BorderBrush" Value="{StaticResource SuccessColor}" />
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                    <Setter Property="BorderBrush" Value="{StaticResource ButtonHoverColor}" />
                                </KeyFrame>
                            </Animation>
                        </Style.Animations>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*, Auto, *">
                            <Grid ColumnDefinitions="Auto, *" VerticalAlignment="Top">
                                <!-- Row 0: Source word + action buttons -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                                    <TextBlock Text="{Binding SourceWord.Name}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5"
                                            HorizontalAlignment="Right">
                                    <Button
                                        Classes="Base Edit"
                                        Command="{Binding $parent[ListBox].((traduction:TraductionManagementViewModel)DataContext).AddNewTraductionCommand}"
                                        CommandParameter="{Binding SourceWord}">
                                        <PathIcon Width="20" Height="20" Foreground="White"
                                                  Data="{StaticResource AddSquareRegular}" />
                                    </Button>
    
                                </StackPanel>
                            </Grid>
                            <Border Grid.Column="1" Width="2" Margin="5 0" VerticalAlignment="Stretch" Background="White">
                                
                            </Border>

                            <!-- Row 1: Target words nested list -->
                            <ItemsControl Grid.Column="2"
                                          VerticalAlignment="Top"
                                          ItemsSource="{Binding TargetWords}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="0 0 0 2" Padding="0 5" BorderBrush="White">
                                            <StackPanel>
                                                <!-- Row 0: Word name + Edit/Delete buttons -->
                                                <Grid ColumnDefinitions="Auto, *, Auto">
                                                    <TextBlock Grid.Column="0" Padding="3 0" VerticalAlignment="Center"> • </TextBlock>
                                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="Bold" Text="{Binding Name}" Margin="0,2" />
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
                                                        <Button Classes="Base Edit" 
                                                                Command="{Binding $parent[ListBox].((traduction:TraductionManagementViewModel)DataContext).EditTraductionCommand}"
                                                                CommandParameter="{Binding .}">
                                                            <PathIcon Width="20" Height="20" Foreground="White" Data="{StaticResource EditRegular}" />
                                                        </Button>
                                                        <Button Classes="Base Delete" 
                                                                Command="{Binding $parent[ListBox].((traduction:TraductionManagementViewModel)DataContext).DeleteTraductionCommand}"
                                                                CommandParameter="{Binding .}">
                                                            <PathIcon Width="20" Height="20" Foreground="White" Data="{StaticResource DeleteRegular}" />
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Row 1: Definitions -->
                                                <Grid ColumnDefinitions="Auto, *, Auto">
                                                    <TextBlock Grid.Column="0" Padding="3 0">• Définitions : </TextBlock>
                                                    <TextBlock Grid.Column="1" FontStyle="Italic" Text="{Binding Definition}"></TextBlock>
                                                    <Button Grid.Column="2" Classes="Base Edit" CommandParameter="{Binding .}">
                                                        <PathIcon Width="20" Height="20" Foreground="White" Data="{StaticResource EditRegular}" />
                                                    </Button>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>
        
    </Grid>
</UserControl>
